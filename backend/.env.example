# Copy to .env and fill in values.
# For local dev, defaults below work with docker-compose.

DATABASE_URL=postgresql+asyncpg://zerohour:zerohour@localhost:5432/zerohour
REDIS_URL=redis://localhost:6379

# Google AI Studio API key — get one at https://aistudio.google.com/apikey
# If unset, the system falls back to the algorithm-only top pick.
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemma-4-27b-it
